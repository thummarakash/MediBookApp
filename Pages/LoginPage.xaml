<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.LoginPage"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,24,20,28" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="6" Margin="0,10,0,0">
                <Label Text="Welcome Back" FontSize="26" FontAttributes="Bold" TextColor="White" />
                <Label Text="Sign in to your account" TextColor="{StaticResource Aqua}" FontSize="13" />
            </VerticalStackLayout>
        </Border>

        <!-- Form Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,30,20,20" Spacing="18">
                <!-- App Logo -->
                <Image Source="medibook_logo.svg" HeightRequest="100" WidthRequest="100" HorizontalOptions="Center" Margin="0,0,0,10" />

                <VerticalStackLayout Spacing="12">
                    <!-- Email Input -->    
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="icon_email.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="EmailEntry" Grid.Column="1" Placeholder="Email address" Keyboard="Email" Style="{StaticResource InputStyle}"
                                   SemanticProperties.Description="Email address input" AutomationId="EmailEntry" />
                        </Grid>
                    </Border>

                    <!-- Password Input -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Image Source="icon_lock.svg" Grid.Column="0" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="PasswordEntry" Grid.Column="1" Placeholder="Password" IsPassword="True" Style="{StaticResource InputStyle}"
                                   SemanticProperties.Description="Password input" AutomationId="PasswordEntry" />
                            <ImageButton x:Name="TogglePasswordButton" Source="icon_eye_close.svg" Grid.Column="2" HeightRequest="20" WidthRequest="20" Padding="0" BackgroundColor="Transparent" Clicked="OnTogglePasswordClicked" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Forgot Password -->
                    <Label Text="Forgot Password?" TextColor="{StaticResource PrimaryBlue}" FontSize="12.5" FontAttributes="Bold" HorizontalOptions="End" Margin="0,2,0,4">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnForgotPasswordClicked" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Button Text="Sign In" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnLoginClicked" Margin="0"
                                AutomationId="SignInBtn" SemanticProperties.Hint="Sign in to your account" />
                        <Button x:Name="BiometricBtn" Grid.Column="1" ImageSource="icon_lock.svg" BackgroundColor="{StaticResource SkyBlue}" Clicked="OnBiometricLoginClicked" WidthRequest="44" HeightRequest="44" CornerRadius="10" Padding="0" VerticalOptions="Center"
                                AutomationId="BiometricLoginBtn" SemanticProperties.Description="Biometric login" />
                    </Grid>

                    <!-- Quick Testing Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,2">
                        <Button Text="Patient Login" Style="{StaticResource OutlineButtonStyle}" Clicked="OnPatientQuickLoginClicked" Padding="0" HeightRequest="46" />
                        <Button Grid.Column="1" Text="Admin Login" Style="{StaticResource OutlineButtonStyle}" Clicked="OnAdminQuickLoginClicked" Padding="0" HeightRequest="46" />
                    </Grid>

                    <Button Text="Continue with Google" ImageSource="icon_google.svg" Style="{StaticResource OutlineButtonStyle}" Clicked="OnGoogleClicked" />

                    <!-- Sign up link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,14,0,0" Spacing="4">
                        <Label Text="Don't have an account?" Style="{StaticResource MutedLabel}" />
                        <Label Text="Sign Up" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" FontSize="13">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
