<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.LoginPage">
    <ScrollView>
        <VerticalStackLayout Padding="24,34" Spacing="22">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Image Source="medibook_logo.svg" HeightRequest="94" WidthRequest="94" />
                <Label Text="MediBook" Style="{StaticResource TitleLabel}" HorizontalTextAlignment="Center" />
                <Label Text="Professional clinic appointment management" Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border BackgroundColor="White" Padding="22" Stroke="#D8E6F8" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="28" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Welcome back" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                    <Label Text="Login to book appointments and manage your documents." Style="{StaticResource MutedLabel}" />

                    <Entry x:Name="EmailEntry" Placeholder="Email address" Keyboard="Email" Style="{StaticResource InputStyle}" />
                    <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" Style="{StaticResource InputStyle}" />

                    <Button Text="Login" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnLoginClicked" />

                    <Button Text="Continue with Google" ImageSource="icon_google.svg" Style="{StaticResource OutlineButtonStyle}" Clicked="OnGoogleClicked" />

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" Margin="0,4">
                        <BoxView HeightRequest="1" BackgroundColor="#D8E6F8" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="New patient?" Style="{StaticResource MutedLabel}" />
                        <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#D8E6F8" VerticalOptions="Center" />
                    </Grid>

                    <Button Text="Create new account" Style="{StaticResource SecondaryButtonStyle}" Clicked="OnRegisterClicked" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Native features: camera, phone dialer, maps, email composer, Google web authentication and SQLite local database." Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
