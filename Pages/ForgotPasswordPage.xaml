<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.ForgotPasswordPage"
             BackgroundColor="{StaticResource PageBg}"
             Title="Forgot Password">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.svg" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Forgot Password" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Recover your account credentials" TextColor="{StaticResource Aqua}" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Form Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="18">
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="20" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Recover Account" Style="{StaticResource SectionTitle}" />
                        <Label Text="Enter your registered email address below. We will send a secure simulation code to verify your identity." Style="{StaticResource MutedLabel}" FontSize="12.5" />

                        <!-- Email Input -->
                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Email Address" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13.5" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Source="icon_email.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,8,0" VerticalOptions="Center" />
                                <Entry x:Name="EmailEntry" Grid.Column="1" Placeholder="Enter registered email" Keyboard="Email" Style="{StaticResource InputStyle}" />
                            </Grid>
                        </Border>

                        <!-- Send Button -->
                        <Button Text="Send Reset Code" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnSendCodeClicked" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
