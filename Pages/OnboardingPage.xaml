<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.OnboardingPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24,20" RowSpacing="10">
        <!-- Top Navigation (Skip button in upper right) -->
        <Button x:Name="SkipBtn" Grid.Row="0" Text="Skip" BackgroundColor="Transparent" TextColor="{StaticResource MutedText}" FontAttributes="Bold" Clicked="OnSkipClicked" HorizontalOptions="End" VerticalOptions="Start" Padding="12,6" />

        <!-- Slides Carousel -->
        <CarouselView x:Name="SlidesCarousel" Grid.Row="1" Loop="False" PositionChanged="OnPositionChanged" HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Spacing="30" VerticalOptions="Center" HorizontalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource OnboardingBg}, Dark={StaticResource CardBgDark}}" HeightRequest="180" WidthRequest="180" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="90" /></Border.StrokeShape>
                            <Image Source="{Binding ImageSource}" HeightRequest="110" WidthRequest="110" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource PrimaryNavy}, Dark=White}" />
                            <Label Text="{Binding Description}" FontSize="15" Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" MaxLines="3" LineBreakMode="WordWrap" WidthRequest="300" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- Bottom Navigation Controls -->
        <Grid Grid.Row="2" HeightRequest="50" Margin="0,10,0,0">
            <!-- Indicator View centered globally -->
            <IndicatorView x:Name="SlidesIndicator" HorizontalOptions="Center" VerticalOptions="Center" />

            <!-- Back Button on the far left -->
            <Button x:Name="PrevBtn" Text="Previous" BackgroundColor="Transparent" TextColor="{StaticResource MutedText}" FontAttributes="Bold" Clicked="OnPrevClicked" IsVisible="False" WidthRequest="80" HeightRequest="44" Padding="0" HorizontalOptions="Start" VerticalOptions="Center" />

            <!-- Next / Finish Button on the far right -->
            <Button x:Name="NextBtn" Text="Next" Style="{StaticResource PrimaryButtonStyle}" WidthRequest="100" HeightRequest="44" Clicked="OnNextClicked" CornerRadius="22" HorizontalOptions="End" VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
