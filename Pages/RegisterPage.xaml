<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.RegisterPage"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,24,20,28" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Margin="0,10,0,0">
                <ImageButton Source="{StaticResource IconBackWhite}" WidthRequest="46" HeightRequest="46" CornerRadius="23" BackgroundColor="Transparent" Clicked="OnBackClicked" Padding="12" />
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Create Account" FontSize="26" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Fill in your details below" TextColor="{StaticResource Aqua}" FontSize="13" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Form Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20" Spacing="16">
                <VerticalStackLayout Spacing="12">
                    <!-- Full Name -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="icon_user.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="FullNameEntry" Grid.Column="1" Placeholder="Full name" Style="{StaticResource InputStyle}" />
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="icon_email.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="EmailEntry" Grid.Column="1" Placeholder="Email address" Keyboard="Email" Style="{StaticResource InputStyle}" />
                        </Grid>
                    </Border>

                    <!-- Phone -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="icon_phone.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="PhoneEntry" Grid.Column="1" Placeholder="Phone number" Keyboard="Telephone" Style="{StaticResource InputStyle}" />
                        </Grid>
                    </Border>

                    <!-- DOB -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="icon_calendar.svg" Grid.Column="0" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <DatePicker x:Name="DobDatePicker" Grid.Column="1" Format="dd/MM/yyyy" TextColor="{StaticResource PrimaryNavy}" BackgroundColor="Transparent" MinimumDate="01/01/1900" VerticalOptions="Center" HorizontalOptions="Fill" />
                        </Grid>
                    </Border>

                    <!-- Password -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Image Source="icon_lock.svg" Grid.Column="0" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="PasswordEntry" Grid.Column="1" Placeholder="Password" IsPassword="True" Style="{StaticResource InputStyle}" />
                            <ImageButton x:Name="TogglePasswordButton" Source="icon_eye_close.svg" Grid.Column="2" HeightRequest="20" WidthRequest="20" Padding="0" BackgroundColor="Transparent" Clicked="OnTogglePasswordClicked" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Confirm Password -->
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Image Source="{StaticResource IconLock}" Grid.Column="0" HeightRequest="20" WidthRequest="20" Margin="0,0,10,0" VerticalOptions="Center" />
                            <Entry x:Name="ConfirmPasswordEntry" Grid.Column="1" Placeholder="Confirm password" IsPassword="True" Style="{StaticResource InputStyle}" />
                            <ImageButton x:Name="ToggleConfirmPasswordButton" Source="icon_eye_close.svg" Grid.Column="2" HeightRequest="20" WidthRequest="20" Padding="0" BackgroundColor="Transparent" Clicked="OnToggleConfirmPasswordClicked" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Button Text="Create Account" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnCreateClicked" Margin="0,6,0,0" />

                    <!-- Login Link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Margin="0,12,0,0" Spacing="4">
                        <Label Text="Already have an account?" Style="{StaticResource MutedLabel}" />
                        <Label Text="Sign In" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" FontSize="13">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
