<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.AdminDashboardPage"
             x:DataType="vm:AdminDashboardViewModel"
             Title="Admin Dashboard">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,24,20,0" Spacing="20">
                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout>
                        <Label Text="Admin Console" Style="{StaticResource TitleLabel}" />
                        <Label Text="MediBook Clinic Administration" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                    <Image Grid.Column="1" Source="medibook_logo.svg" HeightRequest="58" WidthRequest="58" />
                </Grid>

                <!-- Stats Overview Cards -->
                <Label Text="Overview" Style="{StaticResource SectionTitle}" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Padding="14" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding PatientCount}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" />
                            <Label Text="Patients" FontSize="11" TextColor="{StaticResource MutedText}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="14" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding DoctorCount}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" />
                            <Label Text="Doctors" FontSize="11" TextColor="{StaticResource MutedText}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Padding="14" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding BookingCount}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" />
                            <Label Text="Appointments" FontSize="11" TextColor="{StaticResource MutedText}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Action Panels -->
                <Label Text="Management Actions" Style="{StaticResource SectionTitle}" />
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Button Text="Manage Clinics" Style="{StaticResource OutlineButtonStyle}" Clicked="OnManageClinicsClicked" />
                        <Button Text="Manage Doctors" Style="{StaticResource OutlineButtonStyle}" Clicked="OnManageDoctorsClicked" />
                        <Button Text="View All Bookings" Style="{StaticResource OutlineButtonStyle}" Clicked="OnViewAllBookingsClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <controls:CustomTabBar Grid.Row="1" IsAdmin="True" ActiveTab="Home" />
    </Grid>
</ContentPage>
