<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.AppointmentsPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout>
                    <Label Text="My Appointments" Style="{StaticResource TitleLabel}" />
                    <Label Text="All bookings are stored per logged-in user." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="+ Book" Style="{StaticResource SecondaryButtonStyle}" WidthRequest="96" Clicked="OnBookClicked" />
            </Grid>

            <CollectionView x:Name="AppointmentsCollection" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                        <Image Source="icon_calendar.svg" HeightRequest="90" WidthRequest="90" />
                        <Label Text="No appointments yet" Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="Book your first appointment from the Doctors page." Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Padding="18" Margin="0,6" Stroke="#D8E6F8" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                <Image Source="icon_calendar.svg" HeightRequest="66" WidthRequest="66" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding DoctorName}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                    <Label Text="{Binding Department}" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" />
                                    <Label Text="{Binding DisplayDateTime}" Style="{StaticResource MutedLabel}" />
                                    <Label Text="{Binding Reason}" Style="{StaticResource MutedLabel}" />
                                    <Label Text="{Binding Status}" TextColor="{StaticResource Success}" FontAttributes="Bold" FontSize="13" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
