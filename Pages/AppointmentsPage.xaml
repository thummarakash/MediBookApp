<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.AppointmentsPage"
             x:DataType="vm:AppointmentsViewModel">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <!-- Top Curved Header -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <!-- Title & Book Button -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="My Appointments" FontSize="20" FontAttributes="Bold" TextColor="White" />
                            <Label Text="View and manage your scheduled visits" TextColor="{StaticResource Aqua}" FontSize="12.5" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Book Appointment"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HeightRequest="36"
                                CornerRadius="18"
                                FontSize="11.5"
                                Padding="14,0"
                                VerticalOptions="Center"
                                Clicked="OnBookClicked"
                                IsVisible="{Binding IsNotAdmin}" />
                    </Grid>

                    <!-- Search Bar -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="12,0" HeightRequest="48" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="{StaticResource IconOptions}" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" Margin="0,0,8,0" />
                            <Entry Grid.Column="1" Placeholder="Search appointments..." TextChanged="OnSearchTextChanged" VerticalOptions="Center" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        </Grid>
                    </Border>

                    <!-- Tab Chips -->
                    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,4">
                        <Border x:Name="UpcomingChip" BackgroundColor="{StaticResource PrimaryBlue}" Padding="14,6" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Upcoming" />
                            </Border.GestureRecognizers>
                            <Label x:Name="UpcomingChipText" Text="Upcoming" TextColor="White" FontAttributes="Bold" FontSize="11" />
                        </Border>

                        <Border Grid.Column="1" x:Name="PastChip" BackgroundColor="{StaticResource SkyBlue}" Padding="14,6" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Past" />
                            </Border.GestureRecognizers>
                            <Label x:Name="PastChipText" Text="Past" TextColor="{StaticResource PrimaryBlue}" FontSize="11" />
                        </Border>

                        <Border Grid.Column="2" x:Name="CancelledChip" BackgroundColor="{StaticResource SkyBlue}" Padding="14,6" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Cancelled" />
                            </Border.GestureRecognizers>
                            <Label x:Name="CancelledChipText" Text="Cancelled" TextColor="{StaticResource PrimaryBlue}" FontSize="11" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Loading -->
            <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,30" />

            <!-- Appointments List -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Appointments}" SelectionMode="None" ScrollView.VerticalScrollBarVisibility="Never" Margin="20,16,20,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Style="{StaticResource EmptyStateContainerStyle}">
                        <Image Source="{StaticResource IconCalendar}" WidthRequest="48" HeightRequest="48" HorizontalOptions="Center" />
                        <Label Text="No appointments found" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        <Label Text="Your appointments will appear here." Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                        <Button Text="Book Appointment"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HeightRequest="44"
                                CornerRadius="10"
                                Padding="16,0"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"
                                Clicked="OnBookClicked"
                                IsVisible="{Binding IsNotAdmin}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border Style="{StaticResource CardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAppointmentCardTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                <Image Source="{StaticResource IconCalendar}" HeightRequest="50" WidthRequest="50" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding DoctorName}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                        <Border Grid.Column="1" BackgroundColor="{Binding StatusBgColor}" StrokeThickness="0" Padding="8,3" HeightRequest="22">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                            <Label Text="{Binding Status}" TextColor="{Binding StatusColor}" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                    <Label Text="{Binding Department}" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" FontSize="12.5" />
                                    <Label Text="{Binding DisplayDateTime}" FontSize="12" Style="{StaticResource MutedLabel}" />
                                    <Label Text="{Binding ClinicName}" FontSize="11" Style="{StaticResource MutedLabel}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        <controls:CustomTabBar x:Name="CustomTabBarControl" Grid.Row="1" ActiveTab="Appointments" />
    </Grid>
</ContentPage>
