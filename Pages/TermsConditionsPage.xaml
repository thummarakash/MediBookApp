<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.TermsConditionsPage"
             BackgroundColor="#F3F7FC"
             Title="Terms &amp; Conditions">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.png" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Terms &amp; Conditions" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Terms of using the MediBook platform" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <Border BackgroundColor="White" Padding="18" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Terms of Service Agreement" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                        <Label Text="Last updated: June 2026" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                        
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- 1. User Responsibilities -->
                        <Label Text="1. User Responsibilities" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="14" />
                        <Label Text="Users must provide accurate, current, and complete information during registration. You are solely responsible for maintaining the confidentiality of your account credentials, password, and biometric settings." Style="{StaticResource MutedLabel}" FontSize="12.5" />

                        <!-- 2. Appointment Booking -->
                        <Label Text="2. Appointment Booking Terms" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="14" />
                        <Label Text="Appointments are subject to doctor availability and clinic schedules. Scheduling an appointment via MediBook constitutes a direct reservation with the respective clinic." Style="{StaticResource MutedLabel}" FontSize="12.5" />

                        <!-- 3. Cancellation Terms -->
                        <Label Text="3. Cancellation Policy" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="14" />
                        <Label Text="Cancellations must be done at least 2 hours prior to the scheduled slot. Failures to show up or late cancellations may result in clinic admin fees or limitations on future bookings." Style="{StaticResource MutedLabel}" FontSize="12.5" />

                        <!-- 4. Medical Disclaimer -->
                        <Label Text="4. Medical Disclaimer" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="14" />
                        <Label Text="MediBook is a booking and health records platform, not a medical provider. For any medical emergencies, please dial 000 immediately or visit the nearest hospital emergency department." Style="{StaticResource MutedLabel}" FontSize="12.5" />

                        <!-- 5. Limitation of Liability -->
                        <Label Text="5. Limitation of Liability" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="14" />
                        <Label Text="MediBook is not liable for any clinical actions, delays, or diagnoses provided by the registered doctors or clinics. All medical interactions are strictly between you and the healthcare practitioner." Style="{StaticResource MutedLabel}" FontSize="12.5" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
