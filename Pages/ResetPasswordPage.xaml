<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.ResetPasswordPage"
             BackgroundColor="#F3F7FC"
             Title="Reset Password">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.svg" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Reset Password" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Create a new secure login password" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Form Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="18">
                <Border BackgroundColor="White" Padding="20" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Create New Password" Style="{StaticResource SectionTitle}" />
                        
                        <VerticalStackLayout Spacing="2" Margin="0,0,0,6">
                            <Label Text="Resetting password for:" Style="{StaticResource MutedLabel}" />
                            <Label x:Name="EmailSubtitleLabel" Text="user@email.com" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" FontSize="13.5" />
                        </VerticalStackLayout>

                        <!-- Code Entry -->
                        <Label Text="Verification Code" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13.5" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Source="icon_lock.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,8,0" VerticalOptions="Center" />
                                <Entry x:Name="CodeEntry" Grid.Column="1" Placeholder="Enter 6-digit code" Keyboard="Numeric" MaxLength="6" Style="{StaticResource InputStyle}" />
                            </Grid>
                        </Border>

                        <!-- New Password -->
                        <Label Text="New Password" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13.5" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Source="icon_lock.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,8,0" VerticalOptions="Center" />
                                <Entry x:Name="NewPasswordEntry" Grid.Column="1" Placeholder="Minimum 6 characters" IsPassword="True" Style="{StaticResource InputStyle}" />
                            </Grid>
                        </Border>

                        <!-- Confirm Password -->
                        <Label Text="Confirm New Password" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13.5" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Image Source="icon_lock_confirm.svg" HeightRequest="20" WidthRequest="20" Margin="0,0,8,0" VerticalOptions="Center" />
                                <Entry x:Name="ConfirmPasswordEntry" Grid.Column="1" Placeholder="Confirm your password" IsPassword="True" Style="{StaticResource InputStyle}" />
                            </Grid>
                        </Border>

                        <!-- Submit Button -->
                        <Button Text="Reset &amp; Sign In" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnResetClicked" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
