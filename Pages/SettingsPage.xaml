<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.SettingsPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <ImageButton Source="{StaticResource IconBack}" Style="{StaticResource BackButtonStyle}" Clicked="OnBackClicked" />
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Settings" Style="{StaticResource TitleLabel}" />
                    <Label Text="Manage your account and preferences." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </Grid>

            <Border Style="{StaticResource LargeCardStyle}"
                    Stroke="{AppThemeBinding Light={StaticResource LightStroke}, Dark={StaticResource BorderDark}}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Account" Style="{StaticResource SectionTitle}" />
                    <Label x:Name="AccountLabel" Text="Signed in" Style="{StaticResource MutedLabel}" />
                    <Button Text="Google Sign-up / Switch Account" ImageSource="{StaticResource IconGoogle}" Style="{StaticResource OutlineButtonStyle}" Clicked="OnGoogleClicked" />
                    <Button Text="Contact Clinic" ImageSource="{StaticResource IconPhone}" Style="{StaticResource OutlineButtonStyle}" Clicked="OnContactClicked" />
                    <Button Text="Send Test Email" ImageSource="{StaticResource IconEmail}" Style="{StaticResource OutlineButtonStyle}" Clicked="OnTestEmailClicked" />
                    <Button Text="Logout" Style="{StaticResource LogoutButtonStyle}" Clicked="OnLogoutClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
