<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.HomePage"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="#F3F7FC">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,28,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding Greeting}" FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding DateText}" TextColor="#B5D4F4" FontSize="12.5" />
                </VerticalStackLayout>
                <Border Grid.Column="1" HeightRequest="46" WidthRequest="46" StrokeThickness="0" BackgroundColor="{StaticResource PrimaryBlue}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="23" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileAvatarTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="{Binding UserInitials}" TextColor="White" FontAttributes="Bold" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Scrollable Main Area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20" Spacing="20">

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" HorizontalOptions="Center" />

                <!-- Quick Action Cards -->
                <Label Text="Quick Actions" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <!-- Book -->
                    <Border Padding="8,14" BackgroundColor="#E6F1FB" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBookTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_calendar.svg" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                            <Label Text="Book" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Doctors -->
                    <Border Grid.Column="1" Padding="8,14" BackgroundColor="#E6F1FB" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDoctorsTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_doctor.svg" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                            <Label Text="Doctors" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Clinics -->
                    <Border Grid.Column="2" Padding="8,14" BackgroundColor="#E6F1FB" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClinicsTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_clinic.svg" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                            <Label Text="Clinics" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Records -->
                    <Border Grid.Column="3" Padding="8,14" BackgroundColor="#E6F1FB" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDocumentsTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Image Source="icon_document.svg" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                            <Label Text="Records" FontAttributes="Bold" FontSize="11" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Next Appointment Card -->
                <Label Text="Next Appointment" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                <Border BackgroundColor="White" Padding="18" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAppointmentsTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border HeightRequest="48" WidthRequest="48" BackgroundColor="{StaticResource PrimaryBlue}" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Image Source="icon_clinic.svg" HeightRequest="22" WidthRequest="22" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding NextDoctorName}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Grid.Column="1" Text="{Binding NextStatus}" FontSize="11" TextColor="{StaticResource Warning}" FontAttributes="Bold" />
                            </Grid>
                            <Label Text="{Binding NextDoctorDetail}" FontSize="12" Style="{StaticResource MutedLabel}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Upcoming Appointments -->
                <Label Text="Upcoming" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                <CollectionView ItemsSource="{Binding UpcomingAppointments}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="30" Spacing="8" HorizontalOptions="Center">
                            <Image Source="icon_calendar.svg" HeightRequest="36" WidthRequest="36" HorizontalOptions="Center" />
                            <Label Margin="0,6,0,0" Text="No upcoming appointments" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                            <Label Text="Book an appointment to get started." Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:Object">
                            <Border BackgroundColor="White" Padding="16" Margin="0,4" Stroke="#E6F1FB" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Image Source="icon_calendar.svg" HeightRequest="44" WidthRequest="44" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding DoctorName}" FontAttributes="Bold" FontSize="14.5" TextColor="{StaticResource PrimaryNavy}" />
                                        <Label Text="{Binding DisplayDateTime}" FontSize="12" Style="{StaticResource MutedLabel}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        <controls:CustomTabBar Grid.Row="2" ActiveTab="Home" />
    </Grid>
</ContentPage>
