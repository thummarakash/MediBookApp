<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.ManageDoctorsPage"
             Title="Manage Doctors">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,24" Spacing="18">
                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <ImageButton Source="icon_back.svg" WidthRequest="46" HeightRequest="46" CornerRadius="23"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Command="{Binding BackCommand}" Padding="12" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Manage Doctors" Style="{StaticResource TitleLabel}" />
                        <Label Text="Add or remove medical practitioners" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Add Doctor Button (visible when form is hidden) -->
                <Button Text="+ Add New Doctor"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HeightRequest="48"
                        CornerRadius="14"
                        Command="{Binding ShowFormCommand}"
                        IsVisible="{Binding IsFormHidden}" />

                <!-- Add / Edit Doctor Form -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource LightStroke}" StrokeThickness="1"
                        IsVisible="{Binding IsFormVisible}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding FormTitle}" Style="{StaticResource SectionTitle}" />

                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Doctor Name" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding DoctorName, Mode=TwoWay}"
                                   Placeholder="Doctor Name (e.g. Dr Sarah Connor)"
                                   Style="{StaticResource InputStyle}" />
                        </Border>

                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Email Address" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding DoctorEmail, Mode=TwoWay}"
                                   Placeholder="Email Address (e.g. sarah@medibook.com)"
                                   Keyboard="Email"
                                   Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- Specialty Multi-Select -->
                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Specialties" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border BackgroundColor="{StaticResource PageBg}" Padding="14,10" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding SelectedSpecialtiesText}" VerticalOptions="Center"
                                           FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                    <ImageButton Grid.Column="1" Source="icon_options.svg" WidthRequest="32" HeightRequest="32"
                                                 Command="{Binding ToggleSpecialtiesDropdownCommand}" />
                                </Grid>
                                <VerticalStackLayout IsVisible="{Binding IsSpecialtiesExpanded}"
                                                     BindableLayout.ItemsSource="{Binding SpecialtySelections}"
                                                     Spacing="4" Margin="0,6,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" Padding="0,2">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Color="{StaticResource PrimaryBlue}" />
                                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center"
                                                       FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Department Multi-Select -->
                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Departments" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border BackgroundColor="{StaticResource PageBg}" Padding="14,10" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding SelectedDepartmentsText}" VerticalOptions="Center"
                                           FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                    <ImageButton Grid.Column="1" Source="icon_options.svg" WidthRequest="32" HeightRequest="32"
                                                 Command="{Binding ToggleDepartmentsDropdownCommand}" />
                                </Grid>
                                <VerticalStackLayout IsVisible="{Binding IsDepartmentsExpanded}"
                                                     BindableLayout.ItemsSource="{Binding DepartmentSelections}"
                                                     Spacing="4" Margin="0,6,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" Padding="0,2">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Color="{StaticResource PrimaryBlue}" />
                                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center"
                                                       FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Fee Per Session -->
                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Fee Per Session (30 Min) ($)" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding FeePerSession, Mode=TwoWay}"
                                   Placeholder="e.g. 90.00"
                                   Keyboard="Numeric"
                                   Style="{StaticResource InputStyle}" />
                        </Border>



                        <!-- Save / Cancel Buttons -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                            <Button Text="{Binding SaveButtonText}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveDoctorCommand}" />
                            <Button Grid.Column="1" Text="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                                    HeightRequest="50" Padding="18,0" CornerRadius="14"
                                    Command="{Binding CancelEditCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Doctors List -->
                <Label Text="Registered Doctors" Style="{StaticResource SectionTitle}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Doctors}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="16" Margin="0,5" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryNavy}" />
                                            <Label Text="{Binding Email, StringFormat='Email: {0}'}" FontSize="12.5" TextColor="{StaticResource PrimaryBlue}" />
                                            <Label Text="{Binding Specialty}" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" FontSize="12.5" />
                                            <Label Text="{Binding Department}" FontSize="12" TextColor="{StaticResource MutedText}" />
                                        </VerticalStackLayout>
                                        <!-- Edit -->
                                        <Button Grid.Column="1" Text="Edit" Style="{StaticResource SecondaryButtonStyle}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.EditDoctorCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                        <!-- Delete -->
                                        <Button Grid.Column="2" Text="Delete" BackgroundColor="{StaticResource DangerBg}" TextColor="{StaticResource LogoutText}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.DeleteDoctorCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                    <Label Text="{Binding ClinicName, StringFormat='Clinic: {0}'}" FontSize="12" FontAttributes="Italic" TextColor="{StaticResource MutedText}" />
                                    <Label Text="{Binding FeePerAppointment, StringFormat='Fee: ${0:F2} / 30 min session'}" FontSize="12" TextColor="{StaticResource PrimaryNavy}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <controls:CustomTabBar Grid.Row="1" IsAdmin="True" ActiveTab="Doctors" />
    </Grid>
</ContentPage>
