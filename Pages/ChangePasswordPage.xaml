<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.ChangePasswordPage"
             BackgroundColor="#F3F7FC"
             Title="Change Password">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.png" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Change Password" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Update your account login security" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Main Form -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="18">
                <Border BackgroundColor="White" Padding="18" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Change Account Password" Style="{StaticResource SectionTitle}" />

                        <!-- Current Password -->
                        <Label Text="Current Password" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry x:Name="CurrentPasswordEntry" Placeholder="Enter current password" IsPassword="True" Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- New Password -->
                        <Label Text="New Password" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry x:Name="NewPasswordEntry" Placeholder="Minimum 6 characters" IsPassword="True" Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- Confirm Password -->
                        <Label Text="Confirm New Password" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="13" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry x:Name="ConfirmPasswordEntry" Placeholder="Re-enter new password" IsPassword="True" Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- Action Button -->
                        <Button Text="Update Password" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnUpdatePasswordClicked" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
