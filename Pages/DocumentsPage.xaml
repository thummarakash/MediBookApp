<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:models="clr-namespace:MediBook.Models"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.DocumentsPage"
             x:DataType="vm:DocumentsViewModel"
             BackgroundColor="{StaticResource PageBg}">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0">
            <!-- Main Layout -->
            <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20,24,20,0">
                <!-- Header with Back Button -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12" Margin="0,0,0,14">
                    <ImageButton Source="icon_back.svg" WidthRequest="46" HeightRequest="46" CornerRadius="23"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="12" Clicked="OnBackClicked" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Medical Records" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                        <Label Text="Access and search your uploaded medical documents" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Grid>


                <!-- Search Bar -->
                <Border Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Stroke="{StaticResource Aqua}" StrokeThickness="1" Padding="12,0" HeightRequest="48" Margin="0,0,0,14">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Image Source="icon_options.svg" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" />
                        <Entry Grid.Column="1" Placeholder="Search records..." TextChanged="OnSearchTextChanged" VerticalOptions="Center" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                    </Grid>
                </Border>

                <!-- Category Filter Chips -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="8" Margin="0,0,0,16">
                    <Border x:Name="AllChip" BackgroundColor="{StaticResource PrimaryBlue}" Padding="14,6" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnChipTapped" CommandParameter="All" /></Border.GestureRecognizers>
                        <Label x:Name="AllChipText" Text="All" TextColor="White" FontAttributes="Bold" FontSize="11" />
                    </Border>
                    <Border Grid.Column="1" x:Name="PrescriptionChip" BackgroundColor="{StaticResource SkyBlue}" Padding="14,6" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnChipTapped" CommandParameter="Prescription" /></Border.GestureRecognizers>
                        <Label x:Name="PrescriptionChipText" Text="Prescriptions" TextColor="{StaticResource PrimaryBlue}" FontSize="11" />
                    </Border>
                    <Border Grid.Column="2" x:Name="BloodChip" BackgroundColor="{StaticResource SkyBlue}" Padding="14,6" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnChipTapped" CommandParameter="Blood Test" /></Border.GestureRecognizers>
                        <Label x:Name="BloodChipText" Text="Blood Tests" TextColor="{StaticResource PrimaryBlue}" FontSize="11" />
                    </Border>
                    <Border Grid.Column="3" x:Name="ReportChip" BackgroundColor="{StaticResource SkyBlue}" Padding="14,6" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnChipTapped" CommandParameter="Report" /></Border.GestureRecognizers>
                        <Label x:Name="ReportChipText" Text="Reports" TextColor="{StaticResource PrimaryBlue}" FontSize="11" />
                    </Border>
                </Grid>

                <!-- Loading -->
                <ActivityIndicator Grid.Row="3" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,30" />

                <!-- Documents List -->
                <CollectionView Grid.Row="3" ItemsSource="{Binding Documents}" IsGrouped="True" SelectionMode="None" ScrollView.VerticalScrollBarVisibility="Never">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="30" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image Source="icon_document.svg" WidthRequest="48" HeightRequest="48" HorizontalOptions="Center" />
                            <Label Text="No medical records found" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                            <Label Text="Upload documents to store them here." Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="vm:DocumentGroup">
                            <Label Text="{Binding Heading}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" Padding="4,10,0,5" />
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MedicalDocument">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Margin="0,5" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                                    <Border BackgroundColor="{StaticResource SkyBlue}" HeightRequest="40" WidthRequest="40" StrokeThickness="0" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                        <Image Source="{Binding IconImage}" WidthRequest="22" HeightRequest="22" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding FileName}" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding UploadedDateText}" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                                    </VerticalStackLayout>
                                    <ImageButton Grid.Column="2" 
                                                 Source="icon_options.svg" 
                                                 WidthRequest="40" 
                                                 HeightRequest="40" 
                                                 Padding="10"
                                                 BackgroundColor="Transparent"
                                                 VerticalOptions="Center"
                                                 Clicked="OnOptionsClicked"
                                                 CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- FAB -->
            <Border HeightRequest="56" WidthRequest="56" BackgroundColor="{StaticResource PrimaryBlue}" HorizontalOptions="End" VerticalOptions="End" Margin="20" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="28" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnUploadClicked" />
                </Border.GestureRecognizers>
                <Image Source="icon_camera.svg" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>
        <controls:CustomTabBar Grid.Row="1" ActiveTab="" />

    </Grid>
</ContentPage>
