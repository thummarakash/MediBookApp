<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.DocumentsPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout>
                    <Label Text="Medical Documents" Style="{StaticResource TitleLabel}" />
                    <Label Text="Upload prescriptions, reports and referrals." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="+ Upload" Style="{StaticResource SecondaryButtonStyle}" WidthRequest="112" Clicked="OnUploadClicked" />
            </Grid>
            <CollectionView x:Name="DocumentsCollection" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
                        <Image Source="icon_document.svg" HeightRequest="90" WidthRequest="90" />
                        <Label Text="No documents uploaded" Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="Use camera or gallery to save documents in local storage." Style="{StaticResource MutedLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Padding="18" Margin="0,6" Stroke="#D8E6F8" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                <Image Source="icon_document.svg" HeightRequest="64" WidthRequest="64" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding DocumentType}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                    <Label Text="{Binding FileName}" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" />
                                    <Label Text="{Binding UploadedDateText}" Style="{StaticResource MutedLabel}" />
                                    <Label Text="{Binding Notes}" Style="{StaticResource MutedLabel}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
