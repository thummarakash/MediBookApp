<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.NotificationSettingsPage"
             BackgroundColor="#F3F7FC">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.png" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Notifications" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Manage app reminders and alerts" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Toggles List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <Border BackgroundColor="White" Padding="18" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <!-- Appointment Reminders -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Appointment Reminders" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="Before appointments" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="True" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" />
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- 24 Hour Reminder -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="24 Hour Reminder" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="Day before" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="True" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" />
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- 1 Hour Reminder -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="1 Hour Reminder" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="1 hour before" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="True" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" />
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- Prescription Refills -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Prescription Refills" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="Refill reminders" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="False" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
