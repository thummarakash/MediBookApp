<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.SecuritySettingsPage"
             BackgroundColor="#F3F7FC">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.png" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Security" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Manage biometric and privacy settings" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <!-- Biometric Login Card -->
                <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                        <!-- Biometric Icon Frame -->
                        <Border BackgroundColor="#E6F1FB" HeightRequest="40" WidthRequest="40" StrokeThickness="0" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Image Source="icon_user.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Biometric Login" FontAttributes="Bold" FontSize="14.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="Face ID / Fingerprint" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                        </VerticalStackLayout>
                        
                        <Switch x:Name="BiometricSwitch" Grid.Column="2" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" Toggled="OnBiometricToggled" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- PIN Security Card -->
                <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                            <!-- PIN Icon Frame -->
                            <Border BackgroundColor="#E6F1FB" HeightRequest="40" WidthRequest="40" StrokeThickness="0" VerticalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <Image Source="icon_lock.svg" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="App PIN Security" FontAttributes="Bold" FontSize="14.5" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="4-digit unlock code" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                            
                            <Switch x:Name="PinSwitch" Grid.Column="2" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" Toggled="OnPinToggled" VerticalOptions="Center" />
                        </Grid>

                        <BoxView x:Name="PinDivider" HeightRequest="1" BackgroundColor="#F3F7FC" IsVisible="False" />

                        <!-- Change PIN option -->
                        <Grid x:Name="ChangePinRow" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4" IsVisible="False">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangePinClicked" />
                            </Grid.GestureRecognizers>
                            <Image Source="icon_lock.svg" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Set or Change Security PIN" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Navigation List Card -->
                <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <!-- Change Password -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangePasswordClicked" />
                            </Grid.GestureRecognizers>
                            <Image Source="icon_lock.svg" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Change Password" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- Privacy Policy -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPrivacyClicked" />
                            </Grid.GestureRecognizers>
                            <Image Source="icon_document.svg" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Privacy Policy" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                        <!-- Terms of Service -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTermsClicked" />
                            </Grid.GestureRecognizers>
                            <Image Source="icon_document.svg" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Terms of Service" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
