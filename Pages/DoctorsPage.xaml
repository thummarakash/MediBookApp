<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.DoctorsPage"
             x:DataType="vm:DoctorsViewModel">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <!-- Top Curved Header -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="Auto,*">
                        <ImageButton Source="{StaticResource IconBack}" Style="{StaticResource BackButtonStyle}" Clicked="OnBackClicked" />
                        <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                            <Label Text="Find a Doctor" FontSize="19" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Choose a specialist for your appointment" Style="{StaticResource HeaderSubtitleLabel}" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Search Bar -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="12,0" HeightRequest="48" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Source="{StaticResource IconOptions}" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" Margin="0,0,8,0" />
                            <Entry Grid.Column="1" Placeholder="Search doctors..." TextChanged="OnSearchTextChanged" VerticalOptions="Center" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Loading -->
            <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,30" />

            <!-- Doctors List -->
            <CollectionView Grid.Row="1" ItemsSource="{Binding Doctors}" SelectionMode="None" Margin="20,16,20,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Style="{StaticResource EmptyStateContainerStyle}">
                        <Image Source="{StaticResource IconDoctor}" HeightRequest="48" WidthRequest="48" HorizontalOptions="Center" />
                        <Label Text="No doctors found" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                        <Label Text="Try a different search term." Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border Style="{StaticResource CardStyle}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDoctorCardTapped" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                <!-- Doctor Avatar -->
                                <Border HeightRequest="52" WidthRequest="52" BackgroundColor="{StaticResource PrimaryBlue}" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                    <Image Source="{StaticResource IconDoctor}" HeightRequest="28" WidthRequest="28" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <!-- Doctor Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" />
                                    <Label Text="{Binding Specialty}" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" FontSize="12.5" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding ClinicName}" FontSize="11.5" Style="{StaticResource MutedLabel}" />
                                        <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                                            <Image Source="{StaticResource IconStar}" HeightRequest="12" WidthRequest="12" VerticalOptions="Center" />
                                            <Label Text="{Binding Rating}" FontSize="11" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        <controls:CustomTabBar Grid.Row="1" ActiveTab="Doctors" />
    </Grid>
</ContentPage>
