<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="#F3F7FC">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <!-- Top Custom Navy Header with Avatar -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="My Profile" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                    
                    <!-- Circular Avatar -->
                    <Border HeightRequest="64" WidthRequest="64" StrokeThickness="2" Stroke="White" BackgroundColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" Margin="0,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                        <Label Text="{Binding UserInitials}" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding UserName}" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Details Scroll Content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,16" Spacing="16">
                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" />

                    <!-- Personal Info Card -->
                    <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Personal Information" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                            <BoxView HeightRequest="1" BackgroundColor="#E6F1FB" />

                            <!-- Email -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_email.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Email}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>

                            <!-- Phone -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_phone.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Phone}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>

                            <!-- Date of Birth -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_calendar.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding DateOfBirth}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>

                            <!-- Blood Type -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_blood_test.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Blood Type: O+" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Health Info Card -->
                    <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Health Details" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                            <BoxView HeightRequest="1" BackgroundColor="#E6F1FB" />

                            <!-- Allergies -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_warning.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Allergies: Penicillin, Pollen" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>

                            <!-- Emergency Contact -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="icon_user.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Emergency: Jane Doe (Spouse)" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Settings Card -->
                    <Border BackgroundColor="White" Padding="16" Stroke="#E6F1FB" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <!-- Medical Records -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMedicalRecordsClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="icon_document.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Medical Records" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                            <!-- Notifications -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNotificationsClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="icon_bell.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Notifications" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                            <!-- Security & Biometrics -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSecurityClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="icon_lock.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Security &amp; Biometrics" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#F3F7FC" />

                            <!-- Sign Out -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSignOutClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="icon_logout.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Sign Out" FontSize="13.5" TextColor="{StaticResource Error}" FontAttributes="Bold" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
        <controls:CustomTabBar x:Name="CustomTabBarControl" Grid.Row="1" ActiveTab="Profile" />
    </Grid>
</ContentPage>
