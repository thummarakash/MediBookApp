<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MediBook.ViewModels"
             xmlns:controls="clr-namespace:MediBook.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MediBook.Pages.ProfilePage"
             x:DataType="vm:ProfileViewModel">
    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" RowDefinitions="Auto,*">
            <!-- Top Custom Navy Header with Avatar -->
            <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="My Profile" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />

                    <!-- Circular Avatar Container with Pencil Overlay -->
                    <Grid HeightRequest="72" WidthRequest="72" HorizontalOptions="Center" Margin="0,4">
                        <Border HeightRequest="64" WidthRequest="64" StrokeThickness="2" Stroke="White" BackgroundColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" VerticalOptions="Center" IsClippedToBounds="True">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvatarClicked" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                            <Grid>
                                <Label Text="{Binding UserInitials}" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding ShowInitials}" />
                                <Image Source="{Binding AvatarUrl}" Aspect="AspectFill" HeightRequest="64" WidthRequest="64" IsVisible="{Binding HasAvatarUrl}" />
                            </Grid>
                        </Border>

                        <!-- Pencil Edit Badge Overlay -->
                        <Border HeightRequest="22" WidthRequest="22" BackgroundColor="White" Stroke="{StaticResource PrimaryBlue}" StrokeThickness="1.5" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,2,2">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvatarClicked" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                            <Image Source="icon_edit.svg" HeightRequest="10" WidthRequest="10" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{StaticResource PrimaryBlue}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>
                    </Grid>

                    <Label Text="{Binding UserName}" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Details Scroll Content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,16" Spacing="16">
                    <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" Color="{StaticResource PrimaryBlue}" />

                    <!-- Setup Alert Banner -->
                    <Border BackgroundColor="{StaticResource WarningBg}" StrokeThickness="0" Padding="14,12" IsVisible="{Binding ShowProfileSetupAlert}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Image Source="icon_warning.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Finish Setting Up Profile" FontAttributes="Bold" TextColor="{StaticResource Warning}" FontSize="13" />
                                <Label Text="Please update your Mobile Number and Date of Birth." TextColor="{StaticResource Warning}" FontSize="11.5" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Personal Info Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Personal Information" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Edit" Style="{StaticResource OutlineButtonStyle}" HeightRequest="32" Padding="10,0" FontSize="11" Command="{Binding StartEditCommand}" IsVisible="{Binding IsNotEditing}" />
                            </Grid>
                            <BoxView Style="{StaticResource DividerStyle}" />

                            <!-- Full Name -->
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="3" IsVisible="{Binding IsEditing}">
                                    <Label Text="Full Name" FontSize="11.5" TextColor="{StaticResource MutedText}" />
                                    <Label Text="*" TextColor="{StaticResource Danger}" FontSize="11.5" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Grid ColumnDefinitions="30,*" ColumnSpacing="4">
                                    <Image Grid.Column="0" Source="icon_user.svg" Style="{StaticResource ListIconStyle}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding UserName}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" HeightRequest="40" VerticalTextAlignment="Center" IsVisible="{Binding IsNotEditing}" />
                                    <Border Grid.Column="1" Style="{StaticResource InputBorderStyle}" IsVisible="{Binding IsEditing}" HeightRequest="40" Margin="0" Padding="10,0">
                                        <Entry Text="{Binding UserName}" Placeholder="Full Name" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" BackgroundColor="Transparent" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Email -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Email (Cannot be changed)" FontSize="11.5" TextColor="{StaticResource MutedText}" IsVisible="{Binding IsEditing}" />
                                <Grid ColumnDefinitions="30,*" ColumnSpacing="4">
                                    <Image Grid.Column="0" Source="{StaticResource IconEmail}" Style="{StaticResource ListIconStyle}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Email}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" HeightRequest="40" VerticalTextAlignment="Center" />
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Phone -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Phone Number" FontSize="11.5" TextColor="{StaticResource MutedText}" IsVisible="{Binding IsEditing}" />
                                <Grid ColumnDefinitions="30,*" ColumnSpacing="4">
                                    <Image Grid.Column="0" Source="{StaticResource IconPhone}" Style="{StaticResource ListIconStyle}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Phone}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" HeightRequest="40" VerticalTextAlignment="Center" IsVisible="{Binding IsNotEditing}" />
                                    <Border Grid.Column="1" Style="{StaticResource InputBorderStyle}" IsVisible="{Binding IsEditing}" HeightRequest="40" Margin="0" Padding="10,0">
                                        <Entry Text="{Binding Phone}" Placeholder="Phone Number" Keyboard="Telephone" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" BackgroundColor="Transparent" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Date of Birth -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Date of Birth" FontSize="11.5" TextColor="{StaticResource MutedText}" IsVisible="{Binding IsEditing}" />
                                <Grid ColumnDefinitions="30,*" ColumnSpacing="4">
                                    <Image Grid.Column="0" Source="{StaticResource IconCalendar}" Style="{StaticResource ListIconStyle}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding DateOfBirth}" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" HeightRequest="40" VerticalTextAlignment="Center" IsVisible="{Binding IsNotEditing}" />
                                    <Border Grid.Column="1" Style="{StaticResource InputBorderStyle}" IsVisible="{Binding IsEditing}" HeightRequest="40" Margin="0" Padding="10,0">
                                        <DatePicker Date="{Binding DateOfBirthDate}" Format="dd/MM/yyyy" TextColor="{StaticResource PrimaryNavy}" BackgroundColor="Transparent" FontSize="13" VerticalOptions="Center" HeightRequest="38" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Save / Cancel Buttons -->
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="End" IsVisible="{Binding IsEditing}" Margin="0,6,0,0">
                                <Button Text="Cancel" Style="{StaticResource OutlineButtonStyle}" HeightRequest="38" Padding="16,0" Command="{Binding CancelEditCommand}" />
                                <Button Text="Save" Style="{StaticResource PrimaryButtonStyle}" HeightRequest="38" Padding="16,0" Command="{Binding SaveChangesCommand}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Health Info Card -->
                    <!-- <Border Style="{StaticResource CardStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Health Details" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                            <BoxView Style="{StaticResource DividerStyle}" />

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="{StaticResource IconWarning}" Style="{StaticResource ListIconStyle}" />
                                <Label Grid.Column="1" Text="Allergies: Penicillin, Pollen" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Image Source="{StaticResource IconUser}" Style="{StaticResource ListIconStyle}" />
                                <Label Grid.Column="1" Text="Emergency: Jane Doe (Spouse)" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border> -->

                    <!-- Settings Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <VerticalStackLayout Spacing="12">
                            <!-- Medical Records -->
                            <VerticalStackLayout IsVisible="{Binding IsNotAdmin}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMedicalRecordsClicked" />
                                    </Grid.GestureRecognizers>
                                    <Image Source="{StaticResource IconDocument}" Style="{StaticResource ListIconStyle}" />
                                    <Label Grid.Column="1" Text="Medical Records" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                                </Grid>
                                <BoxView Style="{StaticResource DividerStyle}" />
                            </VerticalStackLayout>
                            
                            <!-- Notifications -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnNotificationsClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="{StaticResource IconBell}" Style="{StaticResource ListIconStyle}" />
                                <Label Grid.Column="1" Text="Notifications" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Switch Grid.Column="2" IsToggled="{Binding NotificationsEnabled}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" IsVisible="{Binding IsAdmin}" />
                                <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" IsVisible="{Binding IsNotAdmin}" />
                            </Grid>
                            <BoxView Style="{StaticResource DividerStyle}" />

                            <!-- Security & Biometrics -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSecurityClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="{StaticResource IconLock}" Style="{StaticResource ListIconStyle}" />
                                <Label Grid.Column="1" Text="Security &amp; Biometrics" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="›" FontSize="20" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                            </Grid>
                            <BoxView Style="{StaticResource DividerStyle}" />

                            <!-- Sign Out -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="0,4">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSignOutClicked" />
                                </Grid.GestureRecognizers>
                                <Image Source="{StaticResource IconLogout}" Style="{StaticResource ListIconStyle}" />
                                <Label Grid.Column="1" Text="Sign Out" FontSize="13.5" TextColor="{StaticResource Danger}" FontAttributes="Bold" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
        <controls:CustomTabBar x:Name="CustomTabBarControl" Grid.Row="1" ActiveTab="Profile" />
    </Grid>
</ContentPage>
