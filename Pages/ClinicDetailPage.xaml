<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.ClinicDetailPage"
             BackgroundColor="{StaticResource PageBg}">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Custom Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.svg" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Clinic Detail" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Full clinic info and booking options" TextColor="{StaticResource Aqua}" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
                
                <!-- Hero Building Box -->
                <Border HeightRequest="80" WidthRequest="80" StrokeThickness="0" BackgroundColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" Margin="0,4,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Image Source="icon_clinic.svg" WidthRequest="36" HeightRequest="36" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Main Content Scroll -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <!-- Core Clinic Info Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label x:Name="ClinicNameLabel" Text="City Medical Center" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                        
                        <!-- Address -->
                        <HorizontalStackLayout Spacing="8">
                            <Image Source="icon_map.svg" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                            <Label x:Name="ClinicAddressLabel" Text="123 Health St, Sydney NSW" FontSize="13" TextColor="{StaticResource PrimaryNavy}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        
                        <!-- Phone -->
                        <HorizontalStackLayout Spacing="8">
                            <Image Source="icon_phone.svg" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                            <Label x:Name="ClinicPhoneLabel" Text="+61 2 9000 0000" FontSize="13" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        
                        <!-- Rating -->
                        <HorizontalStackLayout Spacing="6">
                            <Image Source="icon_star.svg" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                            <Label x:Name="ClinicRatingLabel" Text="4.8 (234 reviews)" FontSize="13" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Specialty Chips List -->
                <Label Text="Specialties Offered" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" Margin="0,4,0,0" />
                <FlexLayout x:Name="SpecialtiesFlex" Wrap="Wrap" Direction="Row" JustifyContent="Start" AlignItems="Center" AlignContent="Center" Margin="0,-4" />

                <!-- Opening Hours Card -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Opening Hours" FontSize="14.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource SkyBlue}" />
                        <Label x:Name="HoursMonFriLabel" Text="Mon–Fri: 8AM–8PM" FontSize="13" TextColor="{StaticResource PrimaryNavy}" />
                        <Label x:Name="HoursSatSunLabel" Text="Sat: 9AM–5PM • Sun: 10AM–2PM" FontSize="13" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Actions Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                    <Button Text="Directions" Style="{StaticResource PrimaryButtonStyle}" ImageSource="icon_map.svg" HeightRequest="48" Clicked="OnDirectionsClicked" CornerRadius="12" FontSize="13.5" />
                    <Button Grid.Column="1" Text="Book Appointment" Style="{StaticResource OutlineButtonStyle}" HeightRequest="48" Clicked="OnBookClicked" CornerRadius="12" FontSize="13.5" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
