<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.ContactPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <ImageButton Source="icon_back.svg" WidthRequest="46" HeightRequest="46" CornerRadius="23" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Clicked="OnBackClicked" Padding="12" />
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Contact Clinic" Style="{StaticResource TitleLabel}" />
                    <Label Text="Use native phone, email and map actions." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </Grid>

            <Border Padding="24" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="30" /></Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#071A3D" Offset="0" />
                        <GradientStop Color="#287CFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <VerticalStackLayout Spacing="8">
                    <Label Text="MediBook Medical Centre" TextColor="White" FontSize="24" FontAttributes="Bold" />
                    <Label Text="123 Health Street, Sydney NSW" TextColor="{StaticResource TextOnDark}" />
                    <Label Text="Mon - Fri • 8:30 AM - 6:00 PM" TextColor="{StaticResource TextOnDark}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Button Text="Call" ImageSource="icon_phone.svg" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnCallClicked" />
                <Button Grid.Column="1" Text="Email" ImageSource="icon_email.svg" Style="{StaticResource SecondaryButtonStyle}" Clicked="OnEmailClicked" />
                <Button Grid.Row="1" Grid.ColumnSpan="2" Text="Open Directions" ImageSource="icon_map.svg" Style="{StaticResource OutlineButtonStyle}" Clicked="OnMapClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
