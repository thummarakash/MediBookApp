<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.SplashPage">
    <Grid BackgroundColor="{StaticResource PrimaryNavy}">
        <VerticalStackLayout Padding="32" Spacing="24" HorizontalOptions="Center" VerticalOptions="Center">
            <!-- Logo tile in rounded gradient box -->
            <Border HeightRequest="84" WidthRequest="84" StrokeThickness="0" HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3E8BDE" Offset="0.0" />
                        <GradientStop Color="#185FA5" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Image Source="icon_doctor.svg" HeightRequest="44" WidthRequest="44" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Text="MediBook" TextColor="White" FontSize="32" FontAttributes="Bold" HorizontalTextAlignment="Center" />
            <Label Text="Your health, simplified" TextColor="{StaticResource Aqua}" FontSize="15" HorizontalTextAlignment="Center" />
            
            <!-- Progress Bar -->
            <ProgressBar x:Name="SplashProgress" ProgressColor="{StaticResource Blue2}" HeightRequest="4" WidthRequest="180" HorizontalOptions="Center" Margin="0,20,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
