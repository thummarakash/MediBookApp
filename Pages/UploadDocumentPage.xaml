<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.UploadDocumentPage"
             BackgroundColor="#F3F7FC">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Curved Header -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.png" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="White" Clicked="OnBackClicked" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Upload Document" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Attach or scan medical receipts and files" TextColor="#B5D4F4" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Main Content Scroll -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <!-- Card 1: Take Photo (Camera) -->
                <Border BackgroundColor="#E6F1FB" Stroke="{StaticResource PrimaryBlue}" StrokeThickness="1.5" Padding="20" HeightRequest="130">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTakePhotoClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="icon_camera.png" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" />
                        <Label Text="Take a Photo" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14.5" HorizontalOptions="Center" />
                        <Label Text="Use camera to scan document" FontSize="11.5" Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="or" HorizontalOptions="Center" FontSize="12" Style="{StaticResource MutedLabel}" />

                <!-- Card 2: Choose from Gallery / Files -->
                <Border BackgroundColor="White" Stroke="{StaticResource Accent}" StrokeThickness="1.5" Padding="20" HeightRequest="130">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPickPhotoClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                        <Image Source="icon_gallery.png" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" />
                        <Label Text="Upload File or Image" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14.5" HorizontalOptions="Center" />
                        <Label Text="Choose PDF, DOCX, TXT, or Image" FontSize="11.5" Style="{StaticResource MutedLabel}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                
                <!-- Supported Formats Notice -->
                <Label Text="Supported formats: PDF, Images (JPG, PNG), DOCX, TXT (Max size: 10MB)" 
                       FontSize="11" 
                       HorizontalOptions="Center" 
                       TextColor="{StaticResource PrimaryNavy}" 
                       Opacity="0.7" 
                       Margin="0,-5,0,5" />

                <!-- Input Fields Section -->
                <VerticalStackLayout Spacing="12" Margin="0,10,0,0">
                    <!-- File Selection Preview -->
                    <Label x:Name="SelectedFileLabel" Text="No file selected" FontSize="12.5" FontAttributes="Italic" TextColor="{StaticResource PrimaryBlue}" HorizontalOptions="Center" />

                    <!-- Document Name -->
                    <Label Text="Document Name" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Entry x:Name="DocNameEntry" Placeholder="Enter document name (e.g. Blood Test June)" Style="{StaticResource InputStyle}" />
                    </Border>

                    <!-- Document Type Dropdown -->
                    <Label Text="Document Type" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                    <Border Style="{StaticResource InputBorderStyle}" Padding="12,0">
                        <Picker x:Name="DocTypePicker" Title="Select document type" TitleColor="{StaticResource MutedText}"
                                TextColor="{StaticResource PrimaryNavy}" SelectedIndexChanged="OnDocTypeChanged">
                            <Picker.Items>
                                <x:String>Prescription</x:String>
                                <x:String>Blood Test</x:String>
                                <x:String>Report</x:String>
                                <x:String>Referral</x:String>
                                <x:String>Insurance</x:String>
                                <x:String>Other</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>

                    <!-- Custom Type Field (visible only when Other is selected) -->
                    <VerticalStackLayout x:Name="OtherTypePanel" IsVisible="False" Spacing="6">
                        <Label Text="Specify Type" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry x:Name="OtherTypeEntry" Placeholder="e.g. X-Ray, Discharge Summary, Vaccination..."
                                   Style="{StaticResource InputStyle}" />
                        </Border>
                    </VerticalStackLayout>

                    
                    <!-- Notes -->
                    <Label Text="Optional Notes" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Editor x:Name="NotesEditor" Placeholder="Add any extra notes here..." Style="{StaticResource EditorStyle}" HeightRequest="80" />
                    </Border>

                    <!-- Upload Button -->
                    <Button Text="Upload Document" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnSaveClicked" HeightRequest="52" CornerRadius="12" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
