<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.UploadDocumentPage">
    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="16">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Text="‹" WidthRequest="46" HeightRequest="46" CornerRadius="23" BackgroundColor="White" TextColor="{StaticResource PrimaryBlue}" Clicked="OnBackClicked" />
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Upload Document" Style="{StaticResource TitleLabel}" />
                    <Label Text="Use camera or gallery to attach medical files." Style="{StaticResource MutedLabel}" />
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="White" Padding="20" Stroke="#D8E6F8" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="28" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Image x:Name="PreviewImage" Source="icon_camera.svg" HeightRequest="150" WidthRequest="150" HorizontalOptions="Center" />
                    <Picker x:Name="DocumentTypePicker" Title="Select document type">
                        <Picker.Items>
                            <x:String>Prescription</x:String>
                            <x:String>Medical Report</x:String>
                            <x:String>Referral Letter</x:String>
                            <x:String>Insurance Document</x:String>
                            <x:String>ID Document</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="NotesEditor" Placeholder="Optional notes" Style="{StaticResource EditorStyle}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Take Photo" ImageSource="icon_camera.svg" Style="{StaticResource SecondaryButtonStyle}" Clicked="OnTakePhotoClicked" />
                        <Button Grid.Column="1" Text="Gallery" Style="{StaticResource OutlineButtonStyle}" Clicked="OnPickPhotoClicked" />
                    </Grid>
                    <Label x:Name="SelectedFileLabel" Text="No file selected" Style="{StaticResource MutedLabel}" />
                    <Button Text="Save Document" Style="{StaticResource PrimaryButtonStyle}" Clicked="OnSaveClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
