<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MediBook.Pages.BookAppointmentPage"
             BackgroundColor="{StaticResource PageBg}">
    <Grid RowDefinitions="Auto,*">
        <!-- Top Custom Header with Progress Stepper -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource PrimaryNavy}" Padding="20,20,20,24" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,26,26" /></Border.StrokeShape>
            <VerticalStackLayout Spacing="16">
                <!-- Back & Page Title -->
                <Grid ColumnDefinitions="Auto,*">
                    <ImageButton Source="icon_back.svg" WidthRequest="44" HeightRequest="44" CornerRadius="22" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Command="{Binding BackCommand}" Padding="12" HorizontalOptions="Start" />
                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                        <Label Text="Book Appointment" FontSize="19" FontAttributes="Bold" TextColor="White" />
                        <Label x:Name="StepDescriptionLabel" Text="{Binding StepDescription}" TextColor="{StaticResource Aqua}" FontSize="12.5" />
                    </VerticalStackLayout>
                </Grid>

                <!-- 4-Step Stepper Progress Indicator -->
                <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*" HorizontalOptions="FillAndExpand" Margin="10,4">
                    <!-- Step 1 Circle -->
                    <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                        <Border x:Name="Step1Circle" HeightRequest="28" WidthRequest="28" BackgroundColor="{StaticResource PrimaryBlue}" StrokeThickness="0" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Label Text="1" TextColor="White" FontSize="12.5" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label x:Name="Step1Label" Text="Specialty" FontSize="11" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Line 1 -->
                    <BoxView Grid.Column="1" HeightRequest="2" BackgroundColor="{StaticResource Aqua}" WidthRequest="32" VerticalOptions="Center" Margin="0,-16,0,0" />

                    <!-- Step 2 Circle -->
                    <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                        <Border x:Name="Step2Circle" HeightRequest="28" WidthRequest="28" BackgroundColor="{StaticResource PrimaryNavy}" StrokeThickness="1" Stroke="White" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Label Text="2" TextColor="White" FontSize="12.5" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label x:Name="Step2Label" Text="Doctor" FontSize="11" TextColor="{StaticResource Aqua}" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Line 2 -->
                    <BoxView Grid.Column="3" HeightRequest="2" BackgroundColor="{StaticResource Aqua}" WidthRequest="32" VerticalOptions="Center" Margin="0,-16,0,0" />

                    <!-- Step 3 Circle -->
                    <VerticalStackLayout Grid.Column="4" Spacing="4" HorizontalOptions="Center">
                        <Border x:Name="Step3Circle" HeightRequest="28" WidthRequest="28" BackgroundColor="{StaticResource PrimaryNavy}" StrokeThickness="1" Stroke="White" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Label Text="3" TextColor="White" FontSize="12.5" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label x:Name="Step3Label" Text="Date" FontSize="11" TextColor="{StaticResource Aqua}" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Line 3 -->
                    <BoxView Grid.Column="5" HeightRequest="2" BackgroundColor="{StaticResource Aqua}" WidthRequest="32" VerticalOptions="Center" Margin="0,-16,0,0" />

                    <!-- Step 4 Circle -->
                    <VerticalStackLayout Grid.Column="6" Spacing="4" HorizontalOptions="Center">
                        <Border x:Name="Step4Circle" HeightRequest="28" WidthRequest="28" BackgroundColor="{StaticResource PrimaryNavy}" StrokeThickness="1" Stroke="White" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Label Text="4" TextColor="White" FontSize="12.5" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label x:Name="Step4Label" Text="Confirm" FontSize="11" TextColor="{StaticResource Aqua}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Dynamic Container based on Current Step -->
        <Grid Grid.Row="1">
            <!-- STEP 1: Specialty Selection -->
            <ScrollView x:Name="Step1View" IsVisible="{Binding IsStep1Visible}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Select Specialty" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <!-- Specialty Cardiology -->
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="Cardiology" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="Cardiology" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Specialty Neurology -->
                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="Neurology" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="Neurology" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Specialty Dermatology -->
                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="Dermatologist" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="Dermatology" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Specialty Physiotherapy -->
                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="Physiotherapist" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="Physiotherapy" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Specialty General Care -->
                        <Border Grid.Row="2" Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="General Practitioner" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="General Care" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Specialty Mental Health -->
                        <Border Grid.Row="2" Grid.Column="1" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1" HeightRequest="100">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSpecialtyCommand}" CommandParameter="Mental Health Clinician" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="icon_clinic.svg" HeightRequest="32" WidthRequest="32" HorizontalOptions="Center" />
                                <Label Text="Mental Health" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" FontSize="13.5" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>

            <!-- STEP 2: Doctor Selection -->
            <Grid x:Name="Step2View" RowDefinitions="Auto,*" Padding="20" RowSpacing="12" IsVisible="{Binding IsStep2Visible}">
                <VerticalStackLayout Grid.Row="0" Spacing="8">
                    <Label Text="Select Doctor" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                    <SearchBar Placeholder="Search by doctor name..." Text="{Binding SearchText, Mode=TwoWay}" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" HeightRequest="48" Margin="0,0,0,6" />
                </VerticalStackLayout>
                <CollectionView Grid.Row="1" ItemsSource="{Binding FilteredDoctors}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="16" Margin="0,5" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                                    <Border BackgroundColor="{StaticResource SkyBlue}" HeightRequest="52" WidthRequest="52" StrokeThickness="0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                        <Image Source="icon_doctor.svg" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" />
                                        <Label Text="{Binding Availability}" FontSize="12.5" Style="{StaticResource MutedLabel}" />
                                        <Label Text="{Binding ClinicName}" FontSize="12.5" TextColor="{StaticResource PrimaryBlue}" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Text="Select" Style="{StaticResource SecondaryButtonStyle}" HeightRequest="36" Padding="12,0" FontSize="12.5" Command="{Binding BindingContext.SelectDoctorCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- STEP 3: Date & Time -->
            <ScrollView x:Name="Step3View" IsVisible="{Binding IsStep3Visible}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Select Date &amp; Time" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                    
                    <!-- Selected Doctor Card -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="14" Stroke="{StaticResource BorderLight}" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Image Source="icon_doctor.svg" HeightRequest="48" WidthRequest="48" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding SelectedDoctor.Name}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryNavy}" />
                                <Label Text="{Binding SelectedDoctor.ClinicName, StringFormat='{0} • Specialist'}" FontSize="12" Style="{StaticResource MutedLabel}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Date Selection -->
                    <Label Text="Preferred Date" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                    <Border Stroke="{StaticResource Aqua}" StrokeThickness="1" Padding="12,4" BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <DatePicker Date="{Binding SelectedDate, Mode=TwoWay}" MinimumDate="2026-01-01" TextColor="{StaticResource PrimaryNavy}" />
                    </Border>

                    <!-- Time Slots Selector -->
                    <Label Text="Available Time Slots" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" Margin="0,6,0,0" />
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Row="0" Grid.Column="0" Text="09:00 AM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="09:00 AM" HeightRequest="44" Padding="0" />
                        <Button Grid.Row="0" Grid.Column="1" Text="10:30 AM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="10:30 AM" HeightRequest="44" Padding="0" />
                        <Button Grid.Row="0" Grid.Column="2" Text="11:30 AM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="11:30 AM" HeightRequest="44" Padding="0" />
                        <Button Grid.Row="1" Grid.Column="0" Text="01:00 PM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="01:00 PM" HeightRequest="44" Padding="0" />
                        <Button Grid.Row="1" Grid.Column="1" Text="02:30 PM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="02:30 PM" HeightRequest="44" Padding="0" />
                        <Button Grid.Row="1" Grid.Column="2" Text="04:00 PM" Style="{StaticResource OutlineButtonStyle}" Command="{Binding SelectTimeSlotCommand}" CommandParameter="04:00 PM" HeightRequest="44" Padding="0" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>

            <!-- STEP 4: Confirm Booking -->
            <ScrollView x:Name="Step4View" IsVisible="{Binding IsStep4Visible}">
                <VerticalStackLayout Padding="20" Spacing="16">
                    <Label Text="Review and Confirm" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                    
                    <!-- Booking Summary Card -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Appointment Summary" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource PrimaryBlue}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource SkyBlue}" />
                            
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Text="Specialty:" TextColor="{StaticResource MutedText}" FontAttributes="Bold" FontSize="13" WidthRequest="80" />
                                <Label Grid.Column="1" Text="{Binding SelectedSpecialty}" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" FontSize="13.5" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Text="Doctor:" TextColor="{StaticResource MutedText}" FontAttributes="Bold" FontSize="13" WidthRequest="80" />
                                <Label Grid.Column="1" Text="{Binding SelectedDoctor.Name}" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" FontSize="13.5" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Text="Date &amp; Time:" TextColor="{StaticResource MutedText}" FontAttributes="Bold" FontSize="13" WidthRequest="80" />
                                <Label Grid.Column="1" Text="{Binding SummaryDateTimeText}" TextColor="{StaticResource PrimaryNavy}" FontAttributes="Bold" FontSize="13.5" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Text="Consult Fee:" TextColor="{StaticResource MutedText}" FontAttributes="Bold" FontSize="13" WidthRequest="80" />
                                <Label Grid.Column="1" Text="{Binding SelectedDoctor.FeePerAppointment, StringFormat='${0:F2}'}" TextColor="{StaticResource Success}" FontAttributes="Bold" FontSize="14" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Reason Input -->
                    <Label Text="Reason for visit" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" FontSize="14" />
                    <Border Style="{StaticResource InputBorderStyle}">
                        <Editor Text="{Binding ReasonText, Mode=TwoWay}" Placeholder="Explain your health concern briefly..." Style="{StaticResource EditorStyle}" HeightRequest="90" />
                    </Border>

                    <!-- Reminder Preferences -->
                    <HorizontalStackLayout Spacing="8" Margin="0,4">
                        <CheckBox IsChecked="{Binding IsEmailReminderEnabled, Mode=TwoWay}" Color="{StaticResource PrimaryBlue}" />
                        <Label Text="Queue email confirmation &amp; reminders" VerticalOptions="Center" Style="{StaticResource MutedLabel}" />
                    </HorizontalStackLayout>

                    <!-- Submit Button -->
                    <Button Text="Confirm Appointment" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmBookingCommand}" HeightRequest="52" CornerRadius="12" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Custom Confirm Appointment Popup Overlay -->
        <Grid Grid.RowSpan="2" BackgroundColor="{StaticResource OverlayBg}" IsVisible="{Binding IsConfirmPopupVisible}" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
            <!-- Modal Container -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" VerticalOptions="Center" HorizontalOptions="Center" Margin="24" Padding="24" WidthRequest="320" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="28" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <!-- Icon Header -->
                    <Border BackgroundColor="{StaticResource SkyBlue}" HeightRequest="64" WidthRequest="64" HorizontalOptions="Center" StrokeThickness="0" Margin="0,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="32" /></Border.StrokeShape>
                        <Image Source="icon_calendar.svg" WidthRequest="30" HeightRequest="30" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    
                    <Label Text="Confirm Booking" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HorizontalOptions="Center" />
                    <Label Text="Would you like to book this appointment?" FontSize="13" TextColor="{StaticResource MutedText}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />

                    <!-- Brief Summary -->
                    <Border BackgroundColor="{StaticResource PageBg}" Padding="14" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding SelectedDoctor.Name}" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="{Binding SelectedSpecialty}" FontSize="12" TextColor="{StaticResource PrimaryBlue}" FontAttributes="Bold" />
                            <Label Text="{Binding SummaryDateTimeText}" FontSize="12" TextColor="{StaticResource MutedText}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Text="Cancel" Style="{StaticResource OutlineButtonStyle}" Command="{Binding CancelBookingPopupCommand}" HeightRequest="44" CornerRadius="10" Padding="0" FontSize="13" />
                        <Button Grid.Column="1" Text="Yes, Book" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ExecuteBookingCommand}" HeightRequest="44" CornerRadius="10" Padding="0" FontSize="13" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
