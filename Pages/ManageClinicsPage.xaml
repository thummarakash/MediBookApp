<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MediBook.Controls"
             x:Class="MediBook.Pages.ManageClinicsPage"
             Title="Manage Clinics">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,24,20,0" Spacing="18">
                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <ImageButton Source="icon_back.svg" WidthRequest="46" HeightRequest="46" CornerRadius="23"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Command="{Binding BackCommand}" Padding="12" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Manage Clinics" Style="{StaticResource TitleLabel}" />
                        <Label Text="Add, edit or remove clinics" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Clinic Form -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding FormTitle}" Style="{StaticResource SectionTitle}" />

                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding ClinicName, Mode=TwoWay}"
                                   Placeholder="Clinic Name (e.g. Richmond Family Clinic)"
                                   Style="{StaticResource InputStyle}" />
                        </Border>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding ClinicAddress, Mode=TwoWay}"
                                   Placeholder="Address (e.g. 50 Bridge Rd, Richmond VIC 3121)"
                                   Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- Doctors Multi-Select -->
                        <Label Text="Associated Doctors" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        <Border BackgroundColor="{StaticResource PageBg}" Padding="14,10" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Select Doctors" VerticalOptions="Center"
                                           FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                    <ImageButton Grid.Column="1" Source="icon_options.svg" WidthRequest="32" HeightRequest="32"
                                                 Command="{Binding ToggleDoctorsDropdownCommand}" />
                                </Grid>
                                <VerticalStackLayout IsVisible="{Binding IsDoctorsDropdownExpanded}"
                                                     BindableLayout.ItemsSource="{Binding DoctorSelections}"
                                                     Spacing="6" Margin="0,8,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto,*" Padding="0,2">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Color="{StaticResource PrimaryBlue}" />
                                                <Label Grid.Column="1" Text="{Binding Doctor.Name}" VerticalOptions="Center"
                                                       FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Save / Cancel -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                            <Button Text="{Binding SaveButtonText}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveClinicCommand}" />
                            <Button Grid.Column="1" Text="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                                    HeightRequest="50" Padding="18,0" CornerRadius="14"
                                    IsVisible="{Binding IsEditMode}"
                                    Command="{Binding CancelEditCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Clinics List -->
                <Label Text="Registered Clinics" Style="{StaticResource SectionTitle}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Clinics}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="16" Margin="0,5" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="3">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryNavy}" />
                                            <Label Text="{Binding Address}" Style="{StaticResource MutedLabel}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="Edit" Style="{StaticResource SecondaryButtonStyle}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.EditClinicCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                        <Button Grid.Column="2" Text="Delete" BackgroundColor="{StaticResource DangerBg}" TextColor="{StaticResource LogoutText}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.DeleteClinicCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                    <Label Text="{Binding Latitude, StringFormat='Lat: {0:F4}'}" FontSize="11" TextColor="{StaticResource PrimaryBlue}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <controls:CustomTabBar Grid.Row="1" IsAdmin="True" ActiveTab="Clinics" />
    </Grid>
</ContentPage>
