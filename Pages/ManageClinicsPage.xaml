<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MediBook.Controls"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="MediBook.Pages.ManageClinicsPage"
             Title="Manage Clinics">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,24,20,0" Spacing="18">
                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <ImageButton Source="icon_back.svg" WidthRequest="46" HeightRequest="46" CornerRadius="23"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Command="{Binding BackCommand}" Padding="12" />
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="Manage Clinics" Style="{StaticResource TitleLabel}" />
                        <Label Text="Add, edit or remove clinics" Style="{StaticResource MutedLabel}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Add Clinic Button (visible when form is hidden) -->
                <Button Text="+ Add New Clinic"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HeightRequest="48"
                        CornerRadius="14"
                        Command="{Binding ShowFormCommand}"
                        IsVisible="{Binding IsFormHidden}" />

                <!-- Clinic Form -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="18" Stroke="{StaticResource LightStroke}" StrokeThickness="1"
                        IsVisible="{Binding IsFormVisible}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding FormTitle}" Style="{StaticResource SectionTitle}" />

                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Clinic Name" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding ClinicName, Mode=TwoWay}"
                                   Placeholder="Clinic Name (e.g. Richmond Family Clinic)"
                                   Style="{StaticResource InputStyle}" />
                        </Border>
                        
                        <HorizontalStackLayout Spacing="3" Margin="0,4,0,0">
                            <Label Text="Address" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                            <Label Text="*" TextColor="{StaticResource Danger}" FontAttributes="Bold" FontSize="13.5" />
                        </HorizontalStackLayout>
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Entry Text="{Binding ClinicAddress, Mode=TwoWay}"
                                   Placeholder="Address (e.g. 50 Bridge Rd, Richmond VIC 3121)"
                                   Style="{StaticResource InputStyle}" />
                        </Border>

                        <!-- Map Search Bar -->
                        <Label Text="Search City/Area on Map" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        <Border Style="{StaticResource InputBorderStyle}" HeightRequest="44" Margin="0,2">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry x:Name="MapSearchEntry" Placeholder="Search city/area (e.g. Vesu, Surat)" Style="{StaticResource InputStyle}" />
                                <Button Grid.Column="1" Text="Search" BackgroundColor="{StaticResource PrimaryBlue}" TextColor="White" Padding="12,0" HeightRequest="36" CornerRadius="10" Clicked="OnMapSearchClicked" FontSize="11" FontAttributes="Bold" Margin="4,0" />
                            </Grid>
                        </Border>

                        <!-- Map Picker -->
                        <Label Text="Pin Location on Map" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        <Border Stroke="{StaticResource LightStroke}" StrokeThickness="1" HeightRequest="220" Margin="0,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Grid>
                                <maps:Map x:Name="LocationPickerMap" MapType="Street" IsZoomEnabled="True" IsScrollEnabled="True" MapClicked="OnMapClicked" />
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="Latitude" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource MutedText}" />
                                <Label Text="{Binding ClinicLatitude}" FontSize="13.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HeightRequest="30" VerticalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Longitude" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource MutedText}" />
                                <Label Text="{Binding ClinicLongitude}" FontSize="13.5" FontAttributes="Bold" TextColor="{StaticResource PrimaryNavy}" HeightRequest="30" VerticalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Weekly Schedule -->
                        <Label Text="Weekly Open/Closed Schedule" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        <Border BackgroundColor="{StaticResource PageBg}" Padding="14,10" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <!-- Monday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Monday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding MondayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding MondayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding MondayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding MondayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding MondayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding MondayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Tuesday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Tuesday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding TuesdayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding TuesdayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding TuesdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding TuesdayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding TuesdayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding TuesdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Wednesday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Wednesday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding WednesdayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding WednesdayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding WednesdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding WednesdayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding WednesdayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding WednesdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Thursday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Thursday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding ThursdayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding ThursdayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding ThursdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding ThursdayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding ThursdayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding ThursdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Friday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Friday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding FridayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding FridayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding FridayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding FridayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding FridayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding FridayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Saturday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Saturday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding SaturdayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding SaturdayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding SaturdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding SaturdayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding SaturdayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding SaturdayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource LightStroke}" />

                                <!-- Sunday -->
                                <Grid ColumnDefinitions="90,60,*,20,*" ColumnSpacing="6" VerticalOptions="Center">
                                    <Label Text="Sunday" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryNavy}" />
                                    <Switch Grid.Column="1" IsToggled="{Binding SundayIsOpen, Mode=TwoWay}" OnColor="{StaticResource PrimaryBlue}" ThumbColor="White" VerticalOptions="Center" ScaleX="0.9" ScaleY="0.9" />
                                    <TimePicker Grid.Column="2" Time="{Binding SundayOpenTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding SundayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                    <Label Grid.Column="3" Text="-" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding SundayIsOpen}" />
                                    <TimePicker Grid.Column="4" Time="{Binding SundayCloseTime, Mode=TwoWay}" Format="hh:mm tt" TextColor="{StaticResource PrimaryNavy}" IsVisible="{Binding SundayIsOpen}" VerticalOptions="Center" HeightRequest="38" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Associated Doctor Picker -->
                        <Label Text="Associated Doctor" FontAttributes="Bold" FontSize="13.5" TextColor="{StaticResource PrimaryNavy}" />
                        <Border Style="{StaticResource InputBorderStyle}">
                            <Picker ItemsSource="{Binding AvailableDoctors}"
                                    ItemDisplayBinding="{Binding Name}"
                                    SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                                    Title="Select Doctor"
                                    TextColor="{StaticResource PrimaryNavy}"
                                    TitleColor="{StaticResource MutedText}" />
                        </Border>

                        <!-- Save / Cancel -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,8,0,0">
                            <Button Text="{Binding SaveButtonText}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SaveClinicCommand}" />
                            <Button Grid.Column="1" Text="Cancel" Style="{StaticResource SecondaryButtonStyle}"
                                    HeightRequest="50" Padding="18,0" CornerRadius="14"
                                    Command="{Binding CancelEditCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Clinics List -->
                <Label Text="Registered Clinics" Style="{StaticResource SectionTitle}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Clinics}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" Padding="16" Margin="0,5" Stroke="{StaticResource LightStroke}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Spacing="3">
                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryNavy}" />
                                            <Label Text="{Binding Address}" Style="{StaticResource MutedLabel}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="Edit" Style="{StaticResource SecondaryButtonStyle}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.EditClinicCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                        <Button Grid.Column="2" Text="Delete" BackgroundColor="{StaticResource DangerBg}" TextColor="{StaticResource LogoutText}"
                                                HeightRequest="40" Padding="12,0" CornerRadius="12"
                                                Command="{Binding BindingContext.DeleteClinicCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
        <controls:CustomTabBar Grid.Row="1" IsAdmin="True" ActiveTab="Clinics" />
    </Grid>
</ContentPage>
