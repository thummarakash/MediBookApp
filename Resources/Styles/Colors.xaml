<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="PrimaryNavy">#042C53</Color>
    <Color x:Key="Navy2">#042C53</Color>
    <Color x:Key="PrimaryBlue">#185FA5</Color>
    <Color x:Key="Blue2">#378ADD</Color>
    <Color x:Key="SkyBlue">#E6F1FB</Color>
    <Color x:Key="Aqua">#B5D4F4</Color>
    <Color x:Key="Mint">#DCFCE7</Color>
    <Color x:Key="Accent">#2DD4BF</Color>
    <Color x:Key="Warning">#C2740C</Color>
    <Color x:Key="Danger">#DC2626</Color>
    <Color x:Key="Error">#DC2626</Color>
    <Color x:Key="Success">#15803D</Color>
    <Color x:Key="PageBg">#F3F7FC</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="SoftCard">#E6F1FB</Color>
    <Color x:Key="TextDark">#042C53</Color>
    <Color x:Key="MutedText">#64748B</Color>
    <Color x:Key="BorderLight">#E6F1FB</Color>
    <Color x:Key="White">#FFFFFF</Color>
    
    <!-- Fallback Dark Theme Tokens mapped to Light values to prevent system theme override issues -->
    <Color x:Key="PageBgDark">#F3F7FC</Color>
    <Color x:Key="CardBgDark">#FFFFFF</Color>
    <Color x:Key="BorderDark">#E6F1FB</Color>
    <Color x:Key="TextMutedDark">#64748B</Color>
</ResourceDictionary>
