<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ══ Page ══════════════════════════════════════════════════════════════ -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PageBg}, Dark={StaticResource PageBgDark}}" />
        <Setter Property="Shell.NavBarIsVisible" Value="False" />
        <Setter Property="NavigationPage.HasNavigationBar" Value="False" />
    </Style>

    <!-- ══ Typography ════════════════════════════════════════════════════════ -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource White}}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryNavy}, Dark={StaticResource White}}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryNavy}, Dark={StaticResource White}}" />
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryNavy}, Dark={StaticResource White}}" />
    </Style>

    <Style x:Key="CardTitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryNavy}, Dark={StaticResource White}}" />
    </Style>

    <Style x:Key="MutedLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource TextMutedDark}}" />
        <Setter Property="FontSize" Value="11.5" />
    </Style>

    <Style x:Key="HeaderSubtitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Aqua}" />
        <Setter Property="FontSize" Value="12.5" />
    </Style>

    <!-- ══ Cards ══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Shadow" Value="{StaticResource ShadowSubtle}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="20" />
        </Setter>
    </Style>

    <Style x:Key="LargeCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBg}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Shadow" Value="{StaticResource ShadowMedium}" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="28" />
        </Setter>
    </Style>

    <Style x:Key="SoftCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SkyBlue}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <!-- ══ Quick Action card (used on HomePage) ══════════════════════════════ -->
    <Style x:Key="QuickActionCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SkyBlue}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="8,14" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <!-- ══ Inputs ═════════════════════════════════════════════════════════════ -->
    <Style x:Key="InputBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource CardBgDark}}" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="14" />
        </Setter>
    </Style>

    <Style x:Key="EditorBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource CardBgDark}}" />
        <Setter Property="HeightRequest" Value="110" />
        <Setter Property="Margin" Value="0,5" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="14" />
        </Setter>
    </Style>

    <Style x:Key="InputStyle" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDark}, Dark=White}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MutedText}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="EditorStyle" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDark}, Dark=White}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource MutedText}" />
        <Setter Property="AutoSize" Value="Disabled" />
    </Style>

    <!-- ══ Buttons ════════════════════════════════════════════════════════════ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryBlue}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SkyBlue}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource Blue2}}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="OutlineButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark={StaticResource CardBgDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryBlue}, Dark={StaticResource Blue2}}" />
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="LogoutButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource LogoutBg}" />
        <Setter Property="TextColor" Value="{StaticResource LogoutText}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style x:Key="FABStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryBlue}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="24" />
    </Style>

    <!-- ══ Keypad ═════════════════════════════════════════════════════════════ -->
    <Style x:Key="KeypadButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SkyBlue}" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryNavy}" />
        <Setter Property="CornerRadius" Value="35" />
        <Setter Property="WidthRequest" Value="70" />
        <Setter Property="HeightRequest" Value="70" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="KeypadTextButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryNavy}" />
        <Setter Property="CornerRadius" Value="35" />
        <Setter Property="WidthRequest" Value="70" />
        <Setter Property="HeightRequest" Value="70" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ══ Filter Chips ══════════════════════════════════════════════════════ -->
    <Style x:Key="ChipActiveStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryBlue}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <Style x:Key="ChipInactiveStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SkyBlue}, Dark={StaticResource CardBgDark}}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <RoundRectangle CornerRadius="16" />
        </Setter>
    </Style>

    <!-- ══ Back Button ════════════════════════════════════════════════════════ -->
    <Style x:Key="BackButtonStyle" TargetType="ImageButton">
        <Setter Property="WidthRequest" Value="44" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="Padding" Value="11" />
        <Setter Property="HorizontalOptions" Value="Start" />
    </Style>

    <!-- ══ Icon Image (inline list icons) ════════════════════════════════════ -->
    <Style x:Key="ListIconStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="18" />
        <Setter Property="HeightRequest" Value="18" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CardIconStyle" TargetType="Image">
        <Setter Property="WidthRequest" Value="24" />
        <Setter Property="HeightRequest" Value="24" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <!-- ══ Divider ═════════════════════════════════════════════════════════════ -->
    <Style x:Key="DividerStyle" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}" />
    </Style>

    <!-- ══ Empty State ════════════════════════════════════════════════════════ -->
    <Style x:Key="EmptyStateContainerStyle" TargetType="VerticalStackLayout">
        <Setter Property="Padding" Value="30" />
        <Setter Property="Spacing" Value="12" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

</ResourceDictionary>
