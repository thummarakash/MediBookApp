<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Font size scale -->
    <x:Double x:Key="FontXS">11</x:Double>
    <x:Double x:Key="FontSM">12.5</x:Double>
    <x:Double x:Key="FontBase">14</x:Double>
    <x:Double x:Key="FontMD">15</x:Double>
    <x:Double x:Key="FontLG">16</x:Double>
    <x:Double x:Key="FontXL">18</x:Double>
    <x:Double x:Key="Font2XL">20</x:Double>
    <x:Double x:Key="Font3XL">24</x:Double>
    <x:Double x:Key="FontDisplay">28</x:Double>

</ResourceDictionary>
